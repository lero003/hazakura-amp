HAZAKURA_NOTARY_PASSWORD='xxxx-xxxx-xxxx-xxxx'

# Alternative: keychain profile created by
#   xcrun notarytool store-credentials hazakura-notary
# HAZAKURA_NOTARY_KEYCHAIN_PROFILE='hazakura-notary'

# Alternative: App Store Connect API key
# HAZAKURA_NOTARY_KEY_ID='XXXXXXXXXX'
# HAZAKURA_NOTARY_ISSUER='xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'
# HAZAKURA_NOTARY_KEY_PATH="$HOME/AuthKey_XXXXXXXXXX.p8"
