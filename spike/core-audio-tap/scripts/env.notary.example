# Copy to ../.env.notary (next to project.yml) or repo-root .env.notary
# This file is an example only — never commit real passwords.
#
#   cp scripts/env.notary.example .env.notary
#   # edit values, then:
#   ./scripts/build_dist.sh notarized

HAZAKURA_NOTARY_APPLE_ID='lero003@gmail.com'
